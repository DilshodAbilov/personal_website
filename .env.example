# ============================================================
# Personal Dev Space — Environment variables (EXAMPLE)
# Nusxa oling: cp .env.example .env  (keyin qiymatlarni o'zgartiring)
# ============================================================

# ---------- Django ----------
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Frontend URL — CORS uchun
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------- PostgreSQL ----------
POSTGRES_DB=devspace
POSTGRES_USER=devspace
POSTGRES_PASSWORD=devspace_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---------- Celery ----------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- MinIO (S3-compatible file storage) ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=devspace-media
MINIO_USE_SSL=False

# ---------- Telegram (contact form notifications) ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- Email (transactional) ----------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
